# Eburon CodeBox — Environment Configuration
#
# Copy this file to .env and fill in your values.
# No defaults are assumed — configure each section as needed.

# ── Application ──────────────────────────────────────────────────
# APP_NAME="Eburon CodeBox"

# ── Database ────────────────────────────────────────────────────
# PostgreSQL connection string for Prisma ORM.
# All threads, messages, memories, and skills are stored here.
# DATABASE_URL=postgresql://user:password@localhost:5432/eburon

# ── Provider Mode ───────────────────────────────────────────────
# auto   — automatically selects best available provider by priority
# manual — uses only the explicitly selected provider
LLM_PROVIDER=auto

# ── Provider Priority ───────────────────────────────────────────
# Comma-separated eburon-* aliases in failover order.
PROVIDER_PRIORITY=eburon-sirius,eburon-vega,eburon-zen,eburon-breeze,eburon-vortex,eburon-orion,eburon-polaris

# ── Local Ollama ────────────────────────────────────────────────
# Used by: eburon-sirius, eburon-vega, eburon-orion, eburon-polaris
# OLLAMA_HOST=http://localhost:11434

# ── Cloud Ollama ────────────────────────────────────────────────
# Used by: eburon-vortex
# OLLAMA_CLOUD_HOST=http://your-remote-ollama:11434
# OLLAMA_CLOUD_MODEL=qwen3.6:latest

# ── OpenCode CLI (free models) ──────────────────────────────────
# Used by: eburon-zen
# OPENCODE_MODEL=opencode/deepseek-v4-flash-free

# ── FreeBuff / freebuff2api Proxy ───────────────────────────────
# Used by: eburon-breeze
# Start the proxy: python main.py (from freebuff2api directory)
# FREEBUFF_HOST=http://localhost:8000
# FREEBUFF_MODEL=deepseek/deepseek-v4-flash
# FREEBUFF_API_KEY=

# ── Terminal Settings ───────────────────────────────────────────
# TERMINAL_ENABLED=true
# TERMINAL_REQUIRE_CONFIRMATION=true

# ── Change Application ──────────────────────────────────────────
# AUTO_APPLY_CHANGES=false

# ── Workspace ───────────────────────────────────────────────────
# WORKSPACE_DEFAULT_PATH=

# ── Logging ─────────────────────────────────────────────────────
# LOG_LEVEL=info
